REACT_APP_API_BASE_URL=http://localhost:8080
REACT_APP_API_KEY=change-me

# AI agent (used by the AI chat modal)
REACT_APP_AI_AGENT_BASE_URL=http://127.0.0.1:5000
REACT_APP_AI_AGENT_CHAT_PATH=/chat
REACT_APP_AI_AGENT_REQ_FIELD=message

# Backend-only (not exposed to React because it does NOT start with REACT_APP_)
