# Backend configuration (copy to backend/.env)
DB_DRIVER=mysql+pymysql
DB_USER=root
DB_PASS=change-me
DB_HOST=localhost
DB_NAME=food_app
DB_PORT=3306

# Simple API key for protected endpoints (/api/products, /api/sync/quickcommerce)
API_KEY=change-me

# QuickCommerce API (https://quickcommerceapi.com/docs)
# If QUICKCOMMERCE_API_KEY is empty, the backend falls back to API_KEY for upstream calls.
QUICKCOMMERCE_API_KEY=sk_live_change-me # api key for quickcommerceapi.com, used for upstream calls in /api/sync/quickcommerce. If empty, falls back to API_KEY.
QUICKCOMMERCE_DEFAULT_PLATFORM=BlinkIt
QUICKCOMMERCE_DEFAULT_LAT=12.9021
QUICKCOMMERCE_DEFAULT_LON=77.6639
QUICKCOMMERCE_DEFAULT_PINCODE=
